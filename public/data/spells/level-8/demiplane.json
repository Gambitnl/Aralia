        {
          "name": "Shadowy door",
          "effect": "Creates a shadowy Medium door that can be opened and closed and leads to a 30-foot room."
        },
        {
          "name": "New demiplane",
          "effect": "Each casting can create a new empty demiplane made of wood or stone chosen by the caster."
        },
        {
          "name": "Previous demiplane",
          "effect": "The door can connect to a demiplane the caster created with a previous casting."
        },
        {
          "name": "Known other demiplane",
          "effect": "The door can connect to another creature's demiplane if the caster knows its nature and contents."
        },
        {
          "name": "Vanishing door shunt",
          "effect": "When the door vanishes, creatures inside remain unless they opt to be shunted through and land Prone near the former door."
        }
