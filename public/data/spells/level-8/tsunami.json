                                               },
                                               {
                                                   "name":  "Initial impact",
                                                   "effect":  "When the wall appears, each creature in the area makes a Strength save against 6d10 Bludgeoning damage."
                                               },
                                               {
                                                   "name":  "Moving wall damage",
                                                   "effect":  "A Huge or smaller creature inside the wall or whose space the wall enters saves against 5d10 Bludgeoning damage, only once per round."
                                               },
                                               {
                                                   "name":  "Round decay",
                                                   "effect":  "At the end of each turn, wall height is reduced by 50 feet and later-round damage is reduced by 1d10."
                                               },
                                               {
                                                   "name":  "Swim restriction",
                                                   "effect":  "A creature caught in the wall can move by swimming only if it succeeds on a Strength (Athletics) check against the spell save DC."
                                               },
                                               {
                                                   "name":  "Fall out",
                                                   "effect":  "A creature that moves out of the wall falls to the ground."
                                               },
                                               {
                                                   "name":  "Height ending",
                                                   "effect":  "When the wall reaches 0 feet in height, the spell ends."
