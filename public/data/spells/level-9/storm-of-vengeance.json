      "attackAugments": [],
      "controlOptions": [
        {
          "name": "Initial thunder and deafening",
          "effect": "When the storm appears, creatures under it save against 2d6 Thunder damage and Deafened for the duration."
        },
        {
          "name": "Turn 2 acid rain",
          "effect": "At the start of the caster second later turn, creatures and objects under the cloud take 4d6 Acid damage."
        },
        {
          "name": "Turn 3 lightning bolts",
          "effect": "At the start of the caster third later turn, six bolts strike six different creatures or objects under the cloud for 10d6 Lightning damage with a Dexterity save for half."
        },
        {
          "name": "Turn 4 hailstones",
          "effect": "At the start of the caster fourth later turn, creatures under the cloud take 2d6 Bludgeoning damage."
        },
        {
          "name": "Turns 5 through 10 freezing rain",
          "effect": "On later turns 5 through 10, creatures under the cloud take 1d6 Cold damage."
        },
        {
          "name": "Area control",
          "effect": "Until the spell ends, the area is Difficult Terrain and Heavily Obscured, ranged weapon attacks are impossible there, and strong wind blows through it."
        }
      ],
