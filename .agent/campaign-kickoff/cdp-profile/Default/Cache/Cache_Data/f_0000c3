ranslateY(-50%) rotate(0deg);\r\n  /* Adjust for centering and initial rotation */\r\n  font-size: 0.8em;\r\n  transition: transform 0.2s ease-in-out;\r\n  color: #fcd34d;\r\n  /* amber-300 for better visibility */\r\n}\r\n.prose details[open]>summary::before {\r\n  transform: translateY(-50%) rotate(90deg);\r\n}\r\n/* Styling for standard (non-feature-card) details */\r\n.prose details:not(.feature-card) {\r\n  background-color: rgba(55, 65, 81, 0.15);\r\n  padding: 0.75rem;\r\n  border-radius: 0.375rem;\r\n  margin-bottom: 1rem;\r\n  border-left: 3px solid #fcd34d;\r\n  /* amber-300 */\r\n}\r\n.prose details:not(.feature-card)>summary {\r\n  font-weight: 600;\r\n  color: #fde047;\r\n  /* yellow-400 */\r\n  line-height: 1.5;\r\n}\r\n.prose details:not(.feature-card)>div {\r\n  padding-top: 0.75rem;\r\n  margin-left: 1.25rem;\r\n}\r\n/* Feature Card Styling (Can BE a <details> element) */\r\n.prose .feature-card,\r\n.prose details.feature-card {\r\n  transition: transform .15s ease, background-color .15s ease;\r\n  margin-top: 1.5rem;\r\n  margin-bottom: 1.5rem;\r\n  padding: 1rem;\r\n  border-radius: 0.5rem;\r\n  border-width: 1px;\r\n  border-color: rgba(252, 211, 77, 0.3);\r\n  /* amber-300 with opacity */\r\n  background-color: rgba(30, 41, 55, 0.4);\r\n  /* gray-800 with more opacity */\r\n}\r\n.prose .feature-card:hover,\r\n.prose details.feature-card:hover {\r\n  transform: translateY(-2px);\r\n  background-color: rgba(55, 65, 81, 0.5);\r\n}\r\n/* Summary of a <details class=\"feature-card\"> (main heading) */\r\n.prose details.feature-card>summary {\r\n  font-weight: normal;\r\n  color: inherit;\r\n  padding-top: 0rem;\r\n  padding-bottom: 0.5rem;\r\n  line-height: 1.3;\r\n}\r\n.prose details.feature-card>summary h3 {\r\n  display: inline;\r\n  font-size: 1.25rem !important;\r\n  font-weight: 700 !important;\r\n  color: #fcd34d !important;\r\n  margin: 0 !important;\r\n  padding: 0 !important;\r\n  border-bottom: none !important;\r\n  position: static;\r\n  