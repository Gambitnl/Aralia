{
  "name": "symphony",
  "version": "0.1.0",
  "description": "TypeScript implementation of OpenAI Symphony — autonomous coding agent orchestrator",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "verify:jules-contract": "npm run build && node scripts/run-all-verifiers.mjs",
    "verify:queue": "npm run build && node scripts/verify-queue-next-action.mjs",
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "liquidjs": "^10.21.0",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0"
  }
}
